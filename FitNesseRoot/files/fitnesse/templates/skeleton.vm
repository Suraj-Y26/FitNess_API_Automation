  <header>
   #parse( $headerTemplate )
  </header>

  <article>
   #parse( $mainTemplate )
  </article>

  #if( $!footerTemplate )
  <footer>
   #parse( $footerTemplate )
  </footer>
  #end

  <script>
   /* adjustPadding intentionally removed — no fixed nav bar in ICICI theme */
  </script>

 </body>
